{
    "$jason": {
      "head": {
        "title": "Global Test 2",
        "json_id":"field_1.json",
        "actions": {
          "$show": {
            "type": "$render"
          },
          "$pull": {
            "type": "$reload"
          },
          "save": {
            "type": "$global.set",
            "options": {
              "myvalue1": "{{$get.myvalue1 || ' '}}",
              "secondValue1": "{{$get.secondValue1 || ' '}}",
              "globalSwitch":"{{$get.switchName1 || 'false'}}"
            },
            "success": {
                "type": "$href",
                "options": {
                  "url": "https://sandhyasrini.github.io/json/example-2.json"
                }
            }
          }
        },
        "templates": {
          "body": {
            "header": {
              "menu": {
                "text": "Reset",
                "style": {
                  "size": "15",
                  "font": "Helvetica",
                  "color": "#4f8ff7"
                },
                "action": {
                  "type": "$global.reset",
                  "options": {
                    "items": ["myvalue1"]
                  },
                  "success": {
                    "type": "$close"
                  }
                }
              }
            },
            "sections": [{
              "type": "vertical",
              "items": [{
                  "type": "label",
                  "text": "Global value is: {{$global.myvalue1 || ''}}"
                },
                {
                  "type": "vertical",
                  "style": {
                    "padding": "10"
                  },
                  "components": [{
                    "type": "textfield",
                    "name": "myvalue1",
                    "value": "{{$global.myvalue1 || ''}}",
                    "placeholder": "Add something here"
                  },
                  {
                    "type": "textfield",
                    "name": "secondValue1",
                    "value": "{{$global.secondValue1 || ''}}",
                    "placeholder": "Add something here"
                  },
                  {
                    "type": "switch",
                    "name": "switchName1",
                    "value": "{{$global.globalSwitch || 'false'}}",
                    "contentDescription": "field3"
                  }]
                },
                {
                  "type": "button",
                  "text": "Save Global Variable",
                  "action": {
                    "trigger": "save"
                  }
                }
              ]
            }]
          }
        }
      }
    }
  }