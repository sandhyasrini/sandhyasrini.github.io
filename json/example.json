{
    "$jason": {
      "head": {
        "title": "Global Test 2",
        "json_id":"field.json",
        "actions": {
          "$show": {
            "type": "$render"
          },
          "$pull": {
            "type": "$reload"
          },
          "save": {
            "type": "$global.set",
            "options": {
              "myvalue": "{{$get.myvalue || ' '}}",
              "secondValue": "{{$get.secondValue || ' '}}",
              "ef_s1_Switch": "{{$get.switchName || 'false'}}"
            },
            "success": {
                "type": "$href",
                "options": {
                  "url": "https://sandhyasrini.github.io/json/example-1.json"
                }
            }
          }
        },
        "templates": {
          "body": {
            "header": {
              "menu": {
                "text": "Reset",
                "style": {
                  "size": "15",
                  "font": "Helvetica",
                  "color": "#4f8ff7"
                },
                "action": {
                  "type": "$global.reset",
                  "options": {
                    "items": ["myvalue"]
                  },
                  "success": {
                    "type": "$close"
                  }
                }
              }
            },
            "sections": [{
              "type": "vertical",
              "items": [{
                  "type": "label",
                  "text": "Global value is: {{$global.myvalue || ''}}"
                },
                {
                  "type": "vertical",
                  "style": {
                    "padding": "10"
                  },
                  "components": [{
                    "type": "textfield",
                    "name": "myvalue",
                    "value": "{{$global.myvalue || ''}}",
                    "placeholder": "Add something here"
                  },
                  {
                    "type": "textfield",
                    "name": "secondValue",
                    "value": "{{$global.secondValue || ''}}",
                    "placeholder": "Add something here"
                  },
                  {
                    "type": "switch",
                    "name": "switchName",
                    "value": "{{$global.ef_s1_Switch || 'false'}}",
                    "contentDescription": "field3"
                  }]
                },
                {
                  "type": "button",
                  "text": "Save Global Variable",
                  "action": {
                    "trigger": "save"
                  }
                }
              ]
            }]
          }
        }
      }
    }
  }