{
  "$jason": {
      "head": {
          "title": "Media picker",
          "description": "Tap to select media"
      },
      "body": {
          "sections": [{
              "items": [{
                  "type": "label",
                  "text": "Select media",
                  "action": {
                      "type": "$media.picker",
                      "options": {
                          "edit": "true",
                          "type": "video"
                      },
                      "success": {
                          "type": "$util.alert",
                          "options": {
                              "title": "Selected {{$jason['content_type']}} at",
                              "description": "{{$jason.file_url}}"
                          }
                      }
                  }
              }]
          }]
      }
  }
}