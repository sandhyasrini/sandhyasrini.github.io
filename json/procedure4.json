{
    "$jason": {
      "head": {
        "title": "Camera",
        "description": "Tap to open up camera",
        "actions": {
          "$load": {
            "type": "$media.camera",
            "options": {
              "edit": "true",
              "type": "photo"
            },
            "success": {
              "type": "$render"
            }
          }
        },
        "templates": {
          "body": {
          

            "header":{
                "title":"Hello"
            },
            "sections":
            {
                "items":[
                    {

                        "type": "label",
                        "url": "{{$jason.file_name}}"
                    }
                ]
            }
          }
        }
      }
    }
  }
  