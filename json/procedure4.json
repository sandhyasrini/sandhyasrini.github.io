{
  "$jason": {
    "head": {
      "title": "Camera",
      "description": "Tap to open up camera",
      "actions": {
        "$load": {
          "type": "$media.camera",
          "options": {
            "type": "photo"
          },
          "success": {
            "type": "$render"
          }
        }
      },
      "templates": {
        "body": {
        

          "header":{
              "title":"Hello"
          },
          "sections":
          [{
              "items":[
                  {

                      "type": "label",
                      "text": "{{$params.file_name}}"
                  },
                  {

                      "type": "image",
                      "url": "{{$params.file_name}}",
                      "style":{
                        "width":"25%",
                        "ratio":"2"
                      }
                  }
              ]
          }]
        }
      }
    }
  }
}