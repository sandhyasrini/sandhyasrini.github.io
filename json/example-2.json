{
    "$jason": {
      "head": {
        "title": "Display Values",
        "actions": {
          "$show": {
            "type": "$render"
          }
        },
        "templates": {
          "body": {
            "sections": [
              {
                "type": "vertical",
                "items": [
                  {
                    "type": "label",
                    "text": "EF-Screen-1-TextField --> {{$global.myvalue || ' '}}"
                  },
                  {
                    "type": "label",
                    "text": "EF-Screen-1-TextField 2--> {{$global.secondValue || ' '}}"
                  },
                  {
                    "type": "label",
                    "text": "EF-Screen-1-TextField 2--> {{$global.ef_s1_Switch || 'false'}}"
                  },
                  {
                    "type": "label",
                    "text": "EF-Screen-1-TextField --> {{$global.myvalue1 || ' '}}"
                  },
                  {
                    "type": "label",
                    "text": "EF-Screen-1-TextField 2--> {{$global.secondValue1 || ' '}}"
                  },
                  {
                    "type": "label",
                    "text": "EF-Screen-1-TextField 2--> {{$global.globalSwitch || 'false'}}"
                  },
                  
                  {
                    "type": "button",
                    "text": "Go to Screen-1",
                    "style": {
                      "align": "center",
                      "width": "100%",
                      "height": 50,
                      "color": "#ffffff",
                      "background": "#ff0000"
                    },
                    "action": {
                      "type": "$href",
                      "options": {
                        "url": "https://sandhyasrini.github.io/json/example.json"
                    }
                    }
                  },
                  {
                    "type": "button",
                    "text": "Go to Screen-2",
                    "style": {
                      "align": "center",
                      "width": "100%",
                      "height": 50,
                      "color": "#ffffff",
                      "background": "#00ff00"
                    },
                    "action": {
                      "type": "$href",
                      "options": {
                        "url": "https://sandhyasrini.github.io/json/example-1.json"
                    }
                    }
                  },
                  {
                    "type": "button",
                    "text": "Go to Screen-3",
                    "style": {
                      "align": "center",
                      "width": "100%",
                      "height": 50,
                      "color": "#ffffff",
                      "background": "#0000ff"
                    },
                    "action": {
                      "type": "$href",
                      "options": {
                        "url": "https://pvybhav.github.io/json/Global_Variables/screen-3.json"
                      }
                    }
                  },
                  {
                    "type": "button",
                    "text": "Go Home",
                    "style": {
                      "align": "center",
                      "width": "100%",
                      "height": 50,
                      "color": "#ffffff",
                      "background": "#00ffff"
                    },
                    "action": {
                      "type": "$href",
                      "options": {
                        "url": "https://pvybhav.github.io/json/Global_Variables/index.json"
                      }
                    }
                  }
                ]
              }
            ]
          }
        }
      }
    }
  }