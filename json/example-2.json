{
    "$jason": {
      "head": {
        "title": "Display Values",
        "actions": {
          "$show": {
            "type": "$render"
          }
        },
        "templates": {
          "body": {
            "sections": [
              {
                "type": "vertical",
                "items": [
                  {
                    "type": "label",
                    "text": "EF-Screen-1-TextField --> {{$global.ef_s1_textField || ' '}}"
                  },
                  {
                    "type": "label",
                    "text": "EF-Screen-1-TextArea --> {{$global.ef_s1_TextArea || ' '}}"
                  },
                  {
                    "type": "label",
                    "text": "EF-Screen-2-TextField --> {{$global.ef_s2_textField || ' '}}"
                  },
                  {
                    "type": "label",
                    "text": "EF-Screen-2-TextArea --> {{$global.ef_s2_TextArea || ' '}}"
                  },
                  {
                    "type": "label",
                    "text": "EF-Screen-3-TextField --> {{$global.ef_s3_textField || ' '}}"
                  },
                  {
                    "type": "label",
                    "text": "EF-Screen-3-TextArea --> {{$global.ef_s3_TextArea || ' '}}"
                  },
                  {
                    "type": "button",
                    "text": "Go to Screen-1",
                    "style": {
                      "align": "center",
                      "width": "100%",
                      "height": 50,
                      "color": "#ffffff",
                      "background": "#ff0000"
                    },
                    "action": {
                      "type": "$href",
                      "options": {
                        "url": "https://sandhyasrini.github.io/json/example.json"
                    }
                    }
                  },
                  {
                    "type": "button",
                    "text": "Go to Screen-2",
                    "style": {
                      "align": "center",
                      "width": "100%",
                      "height": 50,
                      "color": "#ffffff",
                      "background": "#00ff00"
                    },
                    "action": {
                      "type": "$href",
                      "options": {
                        "url": "https://sandhyasrini.github.io/json/example-1.json"
                    }
                    }
                  }
                 
                ]
              }
            ]
          }
        }
      }
    }
  }