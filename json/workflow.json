                    }
                },

                "style": {
                    "background": "#5ec6ff",
                    "color": "#ffffff",
                    "font": "Avenir-Bold"
                }
            },
            "style": {

                "background": "#aaaaaa"
            },

            "sections": [{
                "style": {
                    "color": "#ffffff",
