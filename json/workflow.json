                                    "text": "Scope / Background",
                                    "class":"label_style"

                                },
                                {
                                    "type": "label",
                                    "text": "Responsibility",
                                    "class":"label_style"

                                }
                            ]
                        }
                        
                        


                    ]
                }
             ]

            }]
        }

    }
}