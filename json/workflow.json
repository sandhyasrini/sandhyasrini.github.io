{
    "$jason": {
        "head": {
            "styles": {
                "styled_row": {
                    "background": "#d3b023"
                },
                "label_style": {
                    "font": "Avenir-Bold",
                    "size": "18",
                    "color": "#ffffff",
                    "background": "#d3b023",
                    "spacing": "40",
                    "padding": "5"


                }
            }

        },
        "body": {
            "header": {
                "title": {
                    "type": "label",
                    "text": "Training Cable In-Line Splice Repair (3M 8kv kit 5761) ",
                    "style": {
                        "align": "left",
                        "background": "#5ec6ff"
                    }
                },
                "menu": {
                    "text": "MTC-SOP-015",
                    "style": {
                        "color": "#ffffff",
                        "font": "HelveticaNeue-Bold",
                        "size": "18",
